{
  "name": "worker-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply panda-atlas --local",
    "d1:migrate": "wrangler d1 migrations apply panda-atlas --remote",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke_test_worker.mjs --mode=full",
    "smoke:d1": "node scripts/smoke_test_worker.mjs --mode=d1",
    "smoke:http": "node scripts/smoke_test_worker.mjs --mode=http"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
