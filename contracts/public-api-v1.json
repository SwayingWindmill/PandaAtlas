{
  "version": "1",
  "authority": "services/api/openapi/panda-atlas-v1.yaml",
  "schemas": {
    "PandaListItem": {
      "description": "Public panda identity and current-status summary.",
      "fields": {
        "id": { "required": true, "nullable": false },
        "slug": { "required": true, "nullable": false },
        "name_zh": { "required": true, "nullable": false },
        "name_en": { "required": false, "nullable": true },
        "gender": { "required": true, "nullable": false },
        "status": { "required": true, "nullable": false },
        "birth_date": { "required": false, "nullable": true },
        "current_location": { "required": false, "nullable": true },
        "cover_image_url": { "required": false, "nullable": true },
        "search_terms": { "required": false, "nullable": false }
      }
    },
    "DistributionFeatureProperties": {
      "description": "Published map-cell attributes for one versioned distribution projection.",
      "fields": {
        "layer": { "required": true, "nullable": false },
        "cell_code": { "required": true, "nullable": false },
        "density": { "required": false, "nullable": true },
        "snapshot_date": { "required": false, "nullable": true }
      }
    },
    "HabitatFeatureProperties": {
      "description": "Published habitat boundary attributes; province and level may be unknown.",
      "fields": {
        "name": { "required": true, "nullable": false },
        "province": { "required": false, "nullable": true },
        "level": { "required": false, "nullable": true }
      }
    },
    "DistributionSnapshot": {
      "description": "A named, immutable public projection release of distribution data.",
      "fields": {
        "snapshot_date": { "required": true, "nullable": false },
        "version": { "required": true, "nullable": false },
        "notes": { "required": false, "nullable": true }
      }
    },
    "OverviewStats": {
      "description": "Counts computed from one coherent public projection version.",
      "fields": {
        "total_pandas": { "required": true, "nullable": false },
        "active_habitats": { "required": true, "nullable": false },
        "latest_snapshot_date": { "required": true, "nullable": false },
        "wild_distribution_cells": { "required": true, "nullable": false },
        "featured_pandas": { "required": true, "nullable": false }
      }
    },
    "IdentityNameRecord": {
      "description": "One source-linked structured name or alias for a stable panda identity.",
      "fields": {
        "value": { "required": true, "nullable": false },
        "language": { "required": true, "nullable": false },
        "kind": { "required": true, "nullable": false },
        "primary": { "required": true, "nullable": false },
        "source_ids": { "required": true, "nullable": false }
      }
    },
    "LegacySlugRecord": {
      "description": "A source-linked historical slug that resolves to the canonical identity.",
      "fields": {
        "value": { "required": true, "nullable": false },
        "source_ids": { "required": true, "nullable": false }
      }
    },
    "ExternalIdentifierRecord": {
      "description": "A source-linked identifier in an external institutional system.",
      "fields": {
        "system": { "required": true, "nullable": false },
        "value": { "required": true, "nullable": false },
        "source_ids": { "required": true, "nullable": false }
      }
    },
    "PandaIdentityProfile": {
      "description": "Structured public identity attached to one stable panda UUID.",
      "fields": {
        "stable_id": { "required": true, "nullable": false },
        "canonical_slug": { "required": true, "nullable": false },
        "names": { "required": true, "nullable": false },
        "aliases": { "required": true, "nullable": false },
        "legacy_slugs": { "required": true, "nullable": false },
        "external_identifiers": { "required": true, "nullable": false }
      }
    },
    "PublicFactConclusion": {
      "description": "A publishable conclusion derived from one or more retained assertions.",
      "fields": {
        "field": { "required": true, "nullable": false },
        "value": { "required": true, "nullable": true },
        "status": { "required": true, "nullable": false },
        "last_verified_at": { "required": true, "nullable": false },
        "assertion_ids": { "required": true, "nullable": false },
        "source_ids": { "required": true, "nullable": false },
        "candidate_values": { "required": true, "nullable": false },
        "superseded_values": { "required": true, "nullable": false }
      }
    },
    "PublicSourceSummary": {
      "description": "Public-safe source metadata; restricted evidence content is excluded.",
      "fields": {
        "id": { "required": true, "nullable": false },
        "publisher": { "required": true, "nullable": false },
        "title": { "required": true, "nullable": false },
        "url": { "required": true, "nullable": false },
        "published_at": { "required": false, "nullable": true },
        "last_verified_at": { "required": true, "nullable": false },
        "language": { "required": true, "nullable": false },
        "access_state": { "required": true, "nullable": false }
      }
    },
    "LocalizedPublicContent": {
      "description": "One approved localized public summary.",
      "fields": {
        "locale": { "required": true, "nullable": false },
        "summary": { "required": true, "nullable": false }
      }
    },
    "PublicMediaRelease": {
      "description": "Reviewed public media license and rendering policy for one panda.",
      "fields": {
        "license_state": { "required": true, "nullable": false },
        "display_mode": { "required": true, "nullable": false },
        "source_ids": { "required": true, "nullable": false }
      }
    },
    "PublicRevisionSummary": {
      "description": "Version metadata and approved summaries for the current public revision.",
      "fields": {
        "data_version": { "required": true, "nullable": false },
        "public_schema_version": { "required": true, "nullable": false },
        "summaries": { "required": true, "nullable": false }
      }
    },
    "PublicReleaseMetadata": {
      "description": "The immutable dataset release currently served by every public surface.",
      "fields": {
        "dataset_release_version": { "required": true, "nullable": false },
        "public_schema_version": { "required": true, "nullable": false },
        "database_migration_version": { "required": true, "nullable": false },
        "publication_batch_id": { "required": true, "nullable": false },
        "projection_code_version": { "required": true, "nullable": false },
        "released_at": { "required": true, "nullable": false },
        "licenses": { "required": true, "nullable": false }
      }
    },
    "PandaDetail": {
      "description": "One public panda profile with structured identity and fact provenance.",
      "fields": {
        "id": { "required": true, "nullable": false },
        "slug": { "required": true, "nullable": false },
        "name_zh": { "required": true, "nullable": false },
        "name_en": { "required": false, "nullable": true },
        "gender": { "required": true, "nullable": false },
        "status": { "required": true, "nullable": false },
        "birth_date": { "required": false, "nullable": true },
        "current_location": { "required": false, "nullable": true },
        "cover_image_url": { "required": false, "nullable": true },
        "search_terms": { "required": false, "nullable": false },
        "intro": { "required": false, "nullable": true },
        "birthplace": { "required": false, "nullable": true },
        "tags": { "required": false, "nullable": false },
        "father_id": { "required": false, "nullable": true },
        "mother_id": { "required": false, "nullable": true },
        "habitats": { "required": false, "nullable": false },
        "media": { "required": false, "nullable": false },
        "identity": { "required": false, "nullable": true },
        "conclusions": { "required": false, "nullable": false },
        "sources": { "required": false, "nullable": false },
        "current_place": { "required": false, "nullable": true },
        "residencies": { "required": false, "nullable": false },
        "events": { "required": false, "nullable": false },
        "record_tier": { "required": false, "nullable": true },
        "localized_content": { "required": false, "nullable": false },
        "media_release": { "required": false, "nullable": true },
        "public_revision": { "required": false, "nullable": true }
      }
    }
  }
}
