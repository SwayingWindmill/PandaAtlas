{
  "schema_version": 1,
  "title": "PandaAtlas Frontend Release Evidence Manifest",
  "allowed_statuses": [
    "PASS",
    "FAIL",
    "BLOCKED",
    "NOT_APPLICABLE_WITH_REASON"
  ],
  "required_top_level_fields": [
    "schema_version",
    "issue",
    "artifact",
    "risk",
    "public_release",
    "check_groups",
    "staging",
    "human_signoff",
    "release_decision"
  ],
  "required_check_groups": [
    "reproducibility",
    "static_correctness",
    "public_contracts",
    "media_and_content_truth",
    "browser_journeys",
    "automated_accessibility",
    "visual_regression",
    "performance_budgets"
  ],
  "rules": {
    "status_requires_detail": true,
    "not_applicable_requires_reason": true,
    "level_3_requires_staging_and_human_signoff": true,
    "missing_evidence_is_blocked": true,
    "release_go_requires_all_applicable_pass": true
  }
}
