{
  "name": "panda-atlas",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/worker-api"
  ],
  "scripts": {
    "dev:web": "npm run dev -w web",
    "lint:web": "npm run lint -w web",
    "typecheck:web": "npm run typecheck -w web",
    "build:web": "npm run build -w web",
    "smoke:web": "npm run smoke -w web",
    "smoke:web:matrix": "npm run smoke:matrix -w web",
    "preview:web:cf": "npm run preview:cf -w web",
    "deploy:web:cf": "npm run deploy:cf -w web",
    "dev:api:cf": "npm run dev -w worker-api",
    "typecheck:api:cf": "npm run typecheck -w worker-api",
    "smoke:api:cf": "npm run smoke -w worker-api",
    "smoke:api:cf:d1": "npm run smoke:d1 -w worker-api",
    "smoke:api:cf:d1:rollback": "npm run smoke:d1:rollback -w worker-api",
    "smoke:api:cf:http": "npm run smoke:http -w worker-api",
    "check:golden-dataset": "node scripts/golden-dataset/validate.mjs",
    "generate:trusted-identity-aliases": "node scripts/golden-dataset/generate-web-identity-aliases.mjs",
    "check:trusted-identity-aliases": "node scripts/golden-dataset/generate-web-identity-aliases.mjs --check",
    "test:golden-dataset": "node --test scripts/golden-dataset/tests/*.test.mjs",
    "check:panda-curation": "python scripts/curation/validate_panda_curation.py",
    "test:panda-curation": "python -m unittest discover -s scripts/curation/tests -p \"test_validate_panda_curation.py\"",
    "process:panda-media": "uv run --isolated --directory services/api --frozen --extra dev python ../../scripts/curation/process_panda_media.py",
    "test:panda-media": "uv run --isolated --directory services/api --frozen --extra dev python -m unittest discover -s ../../scripts/curation/tests -p \"test_process_panda_media.py\"",
    "build:atlanta-photo-batch": "python scripts/curation/build_atlanta_photo_batch.py",
    "check:atlanta-photo-batch": "python scripts/curation/build_atlanta_photo_batch.py --check",
    "test:atlanta-photo-batch": "python -m unittest discover -s scripts/curation/tests -p \"test_*atlanta_photo*.py\"",
    "check:atlanta-photo-release": "node scripts/release/check-beta-hard-gates.mjs --dataset data/reviewed-batches/2026.07.20.1/source.json --report .release-gate/atlanta-photo-hard-gates.json",
    "check:atlanta-photo-media": "python scripts/curation/upload_atlanta_photo_media.py",
    "upload:atlanta-photo-media": "python scripts/curation/upload_atlanta_photo_media.py --execute --verify-remote",
    "check:public-api-boundary": "node scripts/check-public-api-boundary.mjs",
    "check:beta-hard-gates": "node scripts/release/check-beta-hard-gates.mjs",
    "check:map-visualization-budget": "node scripts/release/check-map-visualization-budget.mjs",
    "check:editorial-home-budget": "node scripts/release/check-editorial-home-budget.mjs",
    "check:my-pandas-budget": "node scripts/release/check-my-pandas-budget.mjs",
    "check:frontend-system-closure": "node scripts/release/check-frontend-system-closure.mjs",
    "check:route-performance-budgets": "node scripts/release/check-route-performance-budgets.mjs",
    "drill:release-recovery": "uv run --directory services/api --frozen --extra dev python scripts/run_release_recovery_drill.py",
    "drill:postgres-attachment-recovery": "uv run --directory services/api --frozen --extra dev python scripts/run_postgres_attachment_recovery_drill.py",
    "test:release-gate": "node --test scripts/release/tests/*.test.mjs",
    "check:frontend-evidence": "node scripts/release/validate-frontend-evidence.mjs data/frontend-evidence/public-beta-2026.07.18.1.json",
    "gate:frontend-evidence": "node scripts/release/validate-frontend-evidence.mjs data/frontend-evidence/public-beta-2026.07.18.1.json --require-pass",
    "classify:frontend-risk": "node scripts/release/classify-frontend-risk.mjs",
    "build:public-release": "uv run --project services/api python services/api/scripts/build_public_release.py",
    "deploy:api:cf": "npm run deploy -w worker-api",
    "release:default": "node scripts/release/default.mjs",
    "release:extended": "node scripts/release/extended.mjs"
  }
}
