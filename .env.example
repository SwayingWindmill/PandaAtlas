# Shared env settings

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend
APP_ENV=development
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
DB_USE_MOCK_FALLBACK=true
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Local-development-only default. Replace with a non-default token outside development.
ADMIN_API_TOKEN=dev-admin-token
# Replace these local-only examples in every deployed environment. Tokens must
# remain unique so a contributor cannot impersonate an independent reviewer.
WORKFLOW_ACTOR_TOKENS_JSON={"11111111-1111-4111-8111-111111111111":"dev-editor-token","22222222-2222-4222-8222-222222222222":"dev-reviewer-token","33333333-3333-4333-8333-333333333333":"dev-publisher-token"}
RUN_ADMIN_IMPORT_SMOKE=0
CORS_ALLOW_ORIGINS=http://localhost:3000
