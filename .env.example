# Shared env settings

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend
APP_ENV=development
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
DB_USE_MOCK_FALLBACK=true
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Local-development-only default. Replace with a non-default token outside development.
ADMIN_API_TOKEN=dev-admin-token
# Required outside local development. Map staff actor UUIDs to distinct bearer
# tokens so a contributor cannot impersonate an independent reviewer.
WORKFLOW_ACTOR_TOKENS_JSON={}
RUN_ADMIN_IMPORT_SMOKE=0
CORS_ALLOW_ORIGINS=http://localhost:3000
